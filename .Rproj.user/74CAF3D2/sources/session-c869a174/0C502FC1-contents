# ---- 13. Régression du prix producteur ----
dist_marche <- qc_s2 %>%
  filter(as.numeric(s02q00) %in% c(14, 15)) %>%
  group_by(grappe) %>%
  summarise(
    temps_marche = min(as.numeric(s02q03), na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(temps_marche = if_else(is.infinite(temps_marche), NA_real_, temps_marche))

coop <- qc_s3 %>%
  mutate(coop_dummy = if_else(as.numeric(s03q03) == 1, 1L, 0L)) %>%
  select(grappe, coop_dummy)

reg_data <- b16_clean %>%
  left_join(dist_marche, by = "grappe") %>%
  left_join(coop,        by = "grappe") %>%
  filter(
    !is.na(temps_marche) & is.finite(temps_marche),
    !is.na(prix_prod_kg) & prix_prod_kg > 0,
    !is.na(qte_vendue_kg) & qte_vendue_kg > 0,
    !is.na(coop_dummy),
    !is.na(hhweight) & hhweight > 0
  ) %>%
  mutate(
    log_prix  = log(prix_prod_kg),
    log_temps = log(temps_marche + 1),
    log_qte   = log(qte_vendue_kg)
  )

if (nrow(reg_data) > 10) {
  model_prix <- lm(
    log_prix ~ log_temps + coop_dummy + as_factor(s16dq08) + log_qte,
    data    = reg_data,
    weights = hhweight
  )
  cat("\n--- Résultats de la régression du prix producteur ---\n")
  print(summary(model_prix))
  saveRDS(model_prix, "figures/model_prix.rds")
  
  sink("figures/regression_prix_producteur.txt")
  cat("MODÈLE : log(prix_prod_kg) ~ log(temps_marche+1) + coop_dummy + canal_vente + log(qte_vendue_kg)\n\n")
  print(summary(model_prix))
  sink()
  
  # Graphique des coefficients
  coefs_prix <- tidy(model_prix, conf.int = TRUE) %>%
    filter(term != "(Intercept)") %>%
    mutate(
      term = recode(term,
                    "log_temps"                                   = "Log(Temps marché+1)",
                    "coop_dummy"                                  = "Existence coopérative",
                    "as_factor(s16dq08)Ménage/Particulier"        = "Canal : Particulier",
                    "as_factor(s16dq08)Coopérative"               = "Canal : Coopérative",
                    "as_factor(s16dq08)Opérateur privé"           = "Canal : Opérateur privé",
                    "log_qte"                                     = "Log(Quantité vendue kg)"
      ),
      term         = fct_reorder(term, estimate),
      significatif = if_else(p.value < 0.05, "p<0.05", "p≥0.05")
    )
  
  p_reg <- ggplot(coefs_prix,
                  aes(x = term, y = estimate, color = significatif)) +
    geom_point(size = 3.5) +
    geom_errorbar(aes(ymin = conf.low, ymax = conf.high),
                  width = 0.25, linewidth = 0.8) +
    geom_hline(yintercept = 0, linetype = "dashed", color = "grey50") +
    coord_flip() +
    scale_color_manual(values = c("p<0.05" = "#1B5E20", "p≥0.05" = "#B71C1C")) +
    labs(
      title    = "Déterminants du prix producteur (régression log-log pondérée)",
      subtitle = "Variable dépendante : log(Prix producteur FCFA/kg) | EHCVM Niger 2021",
      x = NULL, y = "Coefficient (IC 95%)",
      color = NULL
    ) +
    theme_minimal(base_size = 12) +
    theme(plot.title    = element_text(face = "bold"),
          legend.position = "top")
  
  print(p_reg)
  ggsave("figures/regression_prix_producteur.png", p_reg,
         width = 11, height = 6, dpi = 150)
} else {
  cat("⚠️  Pas assez d'observations pour la régression du prix producteur.\n")
}

