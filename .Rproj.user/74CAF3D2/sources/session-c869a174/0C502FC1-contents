# ---- 3. Nettoyage des données de commercialisation (S16D) ----
b16_clean <- b16 %>%
  mutate(
    qte_vendue_kg = as.numeric(s16dq05c),
    montant_vente = as.numeric(s16dq06),
    prix_prod_kg  = if_else(
      !is.na(qte_vendue_kg) & qte_vendue_kg > 0,
      montant_vente / qte_vendue_kg,
      NA_real_
    ),
    culture_code = as.numeric(s16dq01),
    acheteur     = as_factor(s16dq08),
    stockage     = as_factor(s16dq11),
    but_stock    = as_factor(s16dq14)
  ) %>%
  filter(
    !is.na(qte_vendue_kg) & qte_vendue_kg > 0,
    !is.na(montant_vente) & montant_vente > 0,
    !is.na(prix_prod_kg)  & prix_prod_kg  > 0
  ) %>%
  left_join(
    welfare %>% select(grappe, menage, hhweight, region),
    by = c("grappe", "menage")
  ) %>%
  mutate(region = trimws(as.character(as_factor(region))))

# ── Winsorisation P1/P99 du prix producteur ───────────────────────────────────
p01 <- quantile(b16_clean$prix_prod_kg, 0.01, na.rm = TRUE)
p99 <- quantile(b16_clean$prix_prod_kg, 0.99, na.rm = TRUE)
b16_clean <- b16_clean %>%
  filter(prix_prod_kg >= p01 & prix_prod_kg <= p99)

cat("Nombre de lignes S16D après nettoyage + winsorisation :", nrow(b16_clean), "\n")

# ---- 4. Quantité produite totale par ménage et culture (S16C) ----
b6_clean <- b6 %>%
  filter(!is.na(vague)) %>%
  mutate(
    qte_produite_kg = as.numeric(s16cq16a) * as.numeric(s16cq16c),
    culture_code    = as.numeric(s16cq04)
  ) %>%
  filter(!is.na(qte_produite_kg) & qte_produite_kg > 0) %>%
  group_by(grappe, menage, culture_code) %>%
  summarise(qte_produite_totale = sum(qte_produite_kg, na.rm = TRUE),
            .groups = "drop")

# ---- 5. Taux de commercialisation (quantité vendue / quantité produite) ----
labels_culture <- c(
  "1"="Mil","2"="Sorgho","3"="Riz Paddy","4"="Maïs","5"="Souchet",
  "7"="Fonio","8"="Niébé","9"="Voandzou","10"="Arachide",
  "11"="Gombo","12"="Oseille","13"="Sésame","33"="Oignon",
  "37"="Haricot vert","55"="Autre"
)

taux_commer <- b16_clean %>%
  left_join(b6_clean, by = c("grappe", "menage", "culture_code")) %>%
  mutate(
    taux_vente_kg = if_else(
      !is.na(qte_produite_totale) & qte_produite_totale > 0,
      pmin(qte_vendue_kg / qte_produite_totale, 1),  # cap à 1
      NA_real_
    )
  ) %>%
  filter(!is.na(taux_vente_kg)) %>%
  group_by(culture_code) %>%
  summarise(
    nb_pond       = sum(hhweight, na.rm = TRUE),
    taux_pct      = round(weighted.mean(taux_vente_kg, hhweight, na.rm = TRUE) * 100, 1),
    # ✅ Correction : prix moyen pondéré correct
    prix_moyen_kg = round(weighted.mean(prix_prod_kg, hhweight, na.rm = TRUE), 0),
    .groups = "drop"
  ) %>%
  mutate(
    culture_label = labels_culture[as.character(culture_code)],
    culture_label = if_else(is.na(culture_label), as.character(culture_code), culture_label)
  ) %>%
  filter(!is.na(culture_label)) %>%
  arrange(desc(taux_pct))

cat("\n--- Taux de commercialisation par culture (kg vendus / kg produits) ---\n")
