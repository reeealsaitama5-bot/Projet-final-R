  group_by(code_produit) %>%
  summarise(
    prix_conso_moy     = round(weighted.mean(prix_conso_kg, hhweight, na.rm = TRUE), 0),
    part_autoconso_moy = round(weighted.mean(part_autoconso, hhweight, na.rm = TRUE), 1),
    .groups = "drop"
  ) %>%
  mutate(produit_label = case_when(
    code_produit == 7   ~ "Mil",
    code_produit == 8   ~ "Sorgho",
    code_produit == 112 ~ "Niébé",
    code_produit == 114 ~ "Arachide",
    code_produit == 120 ~ "Sésame",
