# ✅ Correction : jointure hhweight depuis welfare avant le calcul
cultures_interet <- c(7, 8, 112, 114, 120, 100, 98, 99, 102, 91)

prix_conso <- b4 %>%
  # ✅ Ajout jointure hhweight
  left_join(welfare %>% select(grappe, menage, hhweight),
            by = c("grappe", "menage")) %>%
  mutate(
    code_produit  = as.numeric(s07bq01),
    qte_achetee   = as.numeric(s07bq07a),
    valeur_achat  = as.numeric(s07bq08),
    qte_totale    = as.numeric(s07bq03a),
    qte_autoconso = as.numeric(s07bq04)
  ) %>%
  filter(
    code_produit %in% cultures_interet,
    !is.na(qte_achetee) & qte_achetee > 0,
    !is.na(valeur_achat) & valeur_achat > 0,
    !is.na(hhweight)
  ) %>%
  mutate(
    prix_conso_kg  = valeur_achat / qte_achetee,
