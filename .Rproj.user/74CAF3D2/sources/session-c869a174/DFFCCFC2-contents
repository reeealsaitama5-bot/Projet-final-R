  Culture = c("Niébé", "Arachide", "Mil"),
  Revenu = c("58,5 millions FCFA", "32,6 millions FCFA", "23,8 millions FCFA"),
  Part = c("--", "--", "14,5 %")
)
kable(revenu_df, col.names = c("Culture", "Revenu de vente généré", "Part du revenu agricole total"),
      caption = "Classement des cultures par revenu de vente", booktabs = TRUE) %>%
  kable_styling(latex_options = c("hold_position"), font_size = 10)
```

```{r fig-revenu, fig.cap="Top 10 des cultures par revenu de vente généré", out.width="85%"}
